    <worksheet name='loyal'>
      <layout-options>
        <title>
          <formatted-text>
            <run bold='true' fontname='Tableau Medium' fontsize='11'>Revenue By Customer&apos;s Loyalty Status</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='Sales+ (combine data)' name='federated.0d2k93f1b67jmn12oayr70nn71rt' />
          </datasources>
          <datasource-dependencies datasource='federated.0d2k93f1b67jmn12oayr70nn71rt'>
            <column datatype='string' name='[Brand]' role='dimension' type='nominal' />
            <column caption='store type ' datatype='string' name='[Calculation_0530842190290945]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [StoreKey] = 0 THEN &apos;Online store&apos;&#13;&#10;ELSE &apos;Physical store&apos; END' />
            </column>
            <column caption='Age in num' datatype='string' name='[Calculation_0530842207657988]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [age_group] = &apos;Teen&apos; THEN &apos;13-19&apos;&#13;&#10;ELSEIF  [age_group] = &apos;Young Adults&apos; THEN &apos;20-35&apos;&#13;&#10;ELSEIF  [age_group] = &apos;Adult&apos; THEN &apos;36-50&apos;&#13;&#10;ELSEIF  [age_group] = &apos;Middle Age&apos; THEN &apos;50-64&apos;&#13;&#10;ELSE &apos;65 and above&apos;&#13;&#10;END' />
            </column>
            <column caption='REVENUE' datatype='real' name='[Calculation_0760088520474635]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='[Unit Price USD]*[Quantity]' />
            </column>
            <column caption='REVENUE %' datatype='real' name='[Calculation_0889007348494341]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='SUM([Calculation_0760088520474635])/TOTAL(SUM([Calculation_0760088520474635]))'>
                <table-calc ordering-type='Rows' />
              </calculation>
            </column>
            <column datatype='string' name='[Country (Customers)]' role='dimension' semantic-role='[Country].[ISO3166_2]' type='nominal' />
            <column datatype='string' name='[Country]' role='dimension' semantic-role='[Country].[ISO3166_2]' type='nominal' />
            <column datatype='date' name='[Order Date]' role='dimension' type='ordinal' />
            <column datatype='integer' name='[Quantity]' role='measure' type='quantitative' />
            <column caption='Store Key' datatype='integer' name='[StoreKey]' role='dimension' type='ordinal' />
            <column datatype='real' name='[Unit Price USD]' role='measure' type='quantitative' />
            <column caption='Age Group' datatype='string' name='[age_group]' role='dimension' type='nominal' />
            <column caption='Churn Status' datatype='string' name='[churn_status]' role='dimension' type='nominal' />
            <column-instance column='[Country (Customers)]' derivation='None' name='[none:Country (Customers):nk]' pivot='key' type='nominal' />
            <column-instance column='[churn_status]' derivation='None' name='[none:churn_status:nk]' pivot='key' type='nominal' />
